DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=YourStrongPassword123!
DB_NAME=kochat_platforma_app

DATABASE_URL=mysql://your_db_user:YourStrongPassword123!@127.0.0.1:3306/kochat_platforma_app

PORT=5000
FRONTEND_URL=http://localhost:5173

# MUHIM: Production da aniq URL kiriting (wildcard * ishlatmang!)
# Development: CORS_ORIGIN=*
# Production:  CORS_ORIGIN=https://yourdomain.com
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# MUHIM: Production da tasodifiy uzun kalit ishlating
# Generatsiya qilish: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_RANDOM_64_CHAR_STRING_IN_PRODUCTION

# =============================================
# WiFi / LOCAL NETWORK testlash (APK uchun)
# =============================================
# 1. cmd/powershell da local IP ni toping: ipconfig (Windows) yoki ip addr (Linux)
#    Masalan: 192.168.1.105
#
# 2. Quyidagilarni o'zgartiring:
#    PORT=4000
#    FRONTEND_URL=http://192.168.1.105:5173
#    CORS_ORIGIN=http://192.168.1.105:5173,http://localhost:5173
#    HOST=0.0.0.0
#
# 3. Backend ishga tushiring (server barcha interfeyslarda tinglaydi):
#    node src/server.js   (HOST=0.0.0.0 bo'lsa avtomatik)
#
# 4. Frontend (Vite) ni tarmoqda oshkor qiling:
#    pnpm --filter client dev -- --host
#    yoki package.json dagi "dev" scriptga: vite --host
#
# 5. APK dagi API URL ni o'zgartiring:
#    http://192.168.1.105:4000
#
# 6. QR skan sahifasi:
#    http://192.168.1.105:4000/scan/BATCH-2026-001
# =============================================

# VITE_API_URL=http://localhost:5000
# Komment holatida frontend localda :5000 ga, prod'da esa shu origin ichidagi /kochat ga ulanadi.
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin12345
ADMIN_NAME=System Administrator
ADMIN_EMAIL=admin@example.com
