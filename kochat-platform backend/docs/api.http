Authorization: Bearer {{token}}
Content-Type: application/json

{
  "customerName": "Green Farm",
  "customerPhone": "+998901112233",
  "locationId": 1,
  "items": [
    {
      "batchId": 1,
      "quantity": 100,
      "unitPrice": 15000
    }
  ]
}

### Order sell
POST {{baseUrl}}/api/orders/1/sell
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "notes": "Naqd sotuv"
}

### Tasks list
GET {{baseUrl}}/api/tasks
Authorization: Bearer {{token}}

### Task create
POST {{baseUrl}}/api/tasks
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "title": "Batchni tekshirish",
  "description": "1-batch sifat nazorati",
  "locationId": 1,
  "assignedTo": 1,
  "priority": "high",
  "status": "open",
  "dueDate": "2026-03-20 18:00:00"
}

