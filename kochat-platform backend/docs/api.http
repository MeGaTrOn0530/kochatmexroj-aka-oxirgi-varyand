@baseUrl = http://localhost:5000
@token = paste_jwt_token_here

### Health
GET {{baseUrl}}/health

### Login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "your_admin_username",
  "password": "your_admin_password"
}

### Mobile login with bearer token
POST {{baseUrl}}/api/auth/login
Content-Type: application/json
X-Kochat-Client: mobile

{
  "username": "your_admin_username",
  "password": "your_admin_password",
  "includeToken": true
}

### Me
GET {{baseUrl}}/api/auth/me
Authorization: Bearer {{token}}

### Logout
POST {{baseUrl}}/api/auth/logout
Authorization: Bearer {{token}}

### Users list
GET {{baseUrl}}/api/users
Authorization: Bearer {{token}}

### User create
POST {{baseUrl}}/api/users
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "fullName": "Ali Valiyev",
  "username": "ali",
  "password": "Ali12345!",
  "role": "bugalter",
  "email": "ali@example.com",
  "phone": "+998901234567",
  "locationId": 1
}

### User update
PUT {{baseUrl}}/api/users/2
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "fullName": "Ali Valiyev Updated",
  "role": "bosh_agranom"
}

### User delete
DELETE {{baseUrl}}/api/users/2
Authorization: Bearer {{token}}

### Locations list
GET {{baseUrl}}/api/locations
Authorization: Bearer {{token}}

### Location create
POST {{baseUrl}}/api/locations
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Andijon filial",
  "code": "AND-01",
  "type": "branch",
  "region": "Andijon",
  "address": "Andijon shahar"
}

### Location update
PUT {{baseUrl}}/api/locations/1
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "address": "Yangilangan manzil"
}

### Seedling types list
GET {{baseUrl}}/api/catalog/seedling-types
Authorization: Bearer {{token}}

### Seedling type create
POST {{baseUrl}}/api/catalog/seedling-types
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Pomidor",
  "code": "POM",
  "description": "Pomidor ko'chati"
}

### Seedling type update
PUT {{baseUrl}}/api/catalog/seedling-types/1
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "description": "Yangilangan izoh"
}

### Seedling type delete
DELETE {{baseUrl}}/api/catalog/seedling-types/1
Authorization: Bearer {{token}}

### Varieties list
GET {{baseUrl}}/api/catalog/varieties
Authorization: Bearer {{token}}

### Varieties by type
GET {{baseUrl}}/api/catalog/varieties/by-type/1
Authorization: Bearer {{token}}

### Variety create
POST {{baseUrl}}/api/catalog/varieties
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "seedlingTypeId": 1,
  "name": "Cherry Red",
  "code": "CHR-RED",
  "description": "Cherry pomidor turi"
}

### Variety update
PUT {{baseUrl}}/api/catalog/varieties/1
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "description": "Yangilangan variety izohi"
}

### Variety delete
DELETE {{baseUrl}}/api/catalog/varieties/1
Authorization: Bearer {{token}}

### Seedlings list
GET {{baseUrl}}/api/seedlings
Authorization: Bearer {{token}}

### Seedlings receive
POST {{baseUrl}}/api/seedlings/receive
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "seedlingTypeId": 1,
  "varietyId": 1,
  "locationId": 1,
  "quantity": 1000,
  "stage": "cassette",
  "labelCodeType": "qr",
  "notes": "Yangi partiya",
  "requiresApproval": true
}

### Seedlings scan
POST {{baseUrl}}/api/seedlings/scan
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "code": "KOCHAT-BATCH-QR:v1:paste_scanned_payload_here"
}

### My scan history
GET {{baseUrl}}/api/seedlings/scans/me?limit=20
Authorization: Bearer {{token}}

### Seedlings stage change
POST {{baseUrl}}/api/seedlings/stage-change
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "batchId": 1,
  "locationId": 1,
  "nextStage": "nursery",
  "defectQuantityChange": 10,
  "notes": "Saralashdan o'tdi"
}

### Seedlings history
GET {{baseUrl}}/api/seedlings/history/1
Authorization: Bearer {{token}}

### Seedlings approve history
POST {{baseUrl}}/api/seedlings/1/approve
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "approvalNote": "Tasdiqlandi"
}

### Transfers list
GET {{baseUrl}}/api/transfers
Authorization: Bearer {{token}}

### Transfer create
POST {{baseUrl}}/api/transfers
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "batchId": 1,
  "fromLocationId": 1,
  "toLocationId": 2,
  "quantity": 300,
  "notes": "Filialga jo'natildi"
}

### Transfer sender confirm
POST {{baseUrl}}/api/transfers/1/sender-confirm
Authorization: Bearer {{token}}

### Transfer head confirm
POST {{baseUrl}}/api/transfers/1/head-confirm
Authorization: Bearer {{token}}

### Transfer receiver confirm
POST {{baseUrl}}/api/transfers/1/receiver-confirm
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "stage": "nursery",
  "notes": "Transfer qabul qilindi"
}

### Orders list
GET {{baseUrl}}/api/orders
Authorization: Bearer {{token}}

