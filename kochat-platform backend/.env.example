NODE_ENV=production
PORT=5000

# MySQL Database (Railway yoki boshqa hosting)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_NAME=kochat_platforma_app

# JWT (uzun random string ishlatish tavsiya etiladi)
JWT_SECRET=your_super_secret_jwt_key_here_min_64_chars
JWT_EXPIRES_HOURS=8
COOKIE_NAME=kochat_token

# CORS - frontend URL yoki * (hammaga ochiq)
CORS_ORIGIN=https://your-frontend-domain.com

# Database avtomatik yaratilsin
AUTO_INIT_DB=true

# Admin foydalanuvchi (birinchi ishga tushganda yaratiladi)
DEFAULT_ADMIN_FULL_NAME=System Admin
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=YourStrongPassword123!
DEFAULT_LOCATION_NAME=Markaziy Ombor
DEFAULT_LOCATION_CODE=HQ

# Telegram Bot (ixtiyoriy)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
